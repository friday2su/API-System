{
    "version": 2,
    "buildCommand": "npm install && cd client && npm install && npm run build",
    "installCommand": "npm install",
    "framework": null,
    "builds": [
        {
            "src": "api/**/*.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/request",
            "dest": "/api/request.js"
        },
        {
            "src": "/(.*)",
            "dest": "/client/dist/$1"
        }
    ]
}
